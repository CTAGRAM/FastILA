# Fast-ILA — environment variables
#
# This is a static site. There are TWO places where values go:
#
#   1. config.js (committed but with empty values) — public values the browser uses
#      • supabaseUrl  → SUPABASE_URL
#      • supabaseAnonKey → SUPABASE_ANON_KEY
#
#   2. Supabase project secrets — set via `supabase secrets set …`. Edge functions
#      read these from Deno.env.
#      • SUPABASE_SERVICE_ROLE_KEY (auto-injected by Supabase)
#      • RESEND_API_KEY            for confirmation emails
#      • PORTAL_URL                public URL of the deployed site
#      • FROM_EMAIL                e.g. bookings@fast-ila.co.uk

# Browser-visible
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server / edge function secrets (do NOT put in config.js — set via Supabase secrets)
RESEND_API_KEY=
PORTAL_URL=https://app.fast-ila.co.uk
FROM_EMAIL=bookings@fast-ila.co.uk
